# SQLite database for Prisma
DATABASE_URL="file:./dev.db"

# Server
PORT=4000

# CORS: browser origin(s) allowed to call the API. Comma-separated for multiple (dev + prod).
CLIENT_URL=http://localhost:5173

# JWT (HS256). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Optional: set both to embed iss/aud in tokens; verification requires match when set.
# JWT_ISSUER=buzzit-api
# JWT_AUDIENCE=buzzit-client

# Access token lifetime (jsonwebtoken `expiresIn` format, e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=15m
